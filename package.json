{
  "name": "automatesaucedemo",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "npx cypress run",
    "cy:open": "npx cypress open",
    "test:allure": "npx cypress run --env allure=true",
    "report:allure": "npx allure generate allure-results --clean -o allure-report && npx allure open",
    "test:mochawesome": "npm run test && npm run report:mochawesome",
    "report:mochawesome": "npx mochawesome-merge \"cypress/reports/mochawesome/*.json\" -o \"cypress/reports/mochawesome.json\" && npx marge \"cypress/reports/mochawesome.json\" -o \"cypress/reports/html-report\"",
    
    "delete:reports": "node -e \"const fs=require('fs');const p='cypress/results';if(fs.existsSync(p)){fs.readdirSync(p).forEach(f=>fs.rmSync(p+'/'+f,{recursive:true,force:true}));}\"",
    "pretest": "npm run delete:reports",
    "merge:reports": "npx mochawesome-merge \"cypress/results/*.json\" -o \"cypress/results/combined-report.json\"",
    "generate:html": "npx marge \"cypress/results/combined-report.json\" -o \"cypress/reports\"",
    "final:report": "npm run merge:reports && npm run generate:html",
    "test:record": "npx cypress run --record --key <your_dashboard_key_here>"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^24.0.1",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.8",
    "@shelex/cypress-allure-plugin": "^2.41.2",
    "allure-commandline": "^2.37.0",
    "cypress": "^15.11.0",
    "esbuild": "^0.27.3",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^5.1.1",
    "mochawesome-report-generator": "^6.3.2",
    "typescript": "^5.9.3"
  }
}
